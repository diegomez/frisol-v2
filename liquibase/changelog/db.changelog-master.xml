    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <!--
    Frisol v2 — Liquibase Changelog
    Orden cronológico de migraciones.
    Cada <include> representa un changeset inmutable.
  -->

  <!-- v1: Estado inicial del proyecto (tablas base) -->
  <include file="001-baseline.xml" relativeToChangelogFile="true"/>
